# Google OAuth (login / identity binding) — copy to .env.local and fill in.
# Create credentials at: https://console.cloud.google.com/apis/credentials
#   OAuth 2.0 Client ID (type: Web application)
#   Authorized redirect URI: https://digital-footprint-health.vercel.app/api/auth/callback
#   (for local dev also add: http://localhost:3000/api/auth/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret used to sign the session cookie (HMAC). Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
